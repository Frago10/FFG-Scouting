# ─────────────────────────────────────────────────────────────
# Email delivery via Web3Forms (free, unlimited submissions).
# ─────────────────────────────────────────────────────────────
#
# How to obtain the key (one-time, ~3 minutes):
#   1. https://web3forms.com  →  "Create your Access Key"
#   2. Enter the inbox that will receive submissions:
#        → jeanpaulfrago10@gmail.com
#   3. Confirm via the verification email Web3Forms sends you
#   4. Copy the access key string
#   5. Paste it below (and as a GitHub secret of the same name)
#
# The key is intentionally PUBLIC — it just identifies which inbox
# Web3Forms should deliver to. Exposing it in the client bundle is
# the supported usage pattern.

NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=replace-me-with-your-web3forms-key

# ─────────────────────────────────────────────────────────────
# Base path (GitHub Pages project sites only).
# ─────────────────────────────────────────────────────────────
#
# Leave empty for local dev, custom domains and User Pages.
# The GitHub Actions workflow sets this automatically to
# "/<repo-name>" so all asset paths resolve under the project URL.
#
# Example for manual local preview of the production build:
#   NEXT_PUBLIC_BASE_PATH=/ffg-scouting
NEXT_PUBLIC_BASE_PATH=
