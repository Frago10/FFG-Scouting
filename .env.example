# Email delivery via Web3Forms (free, unlimited submissions).
#
# How to get a key:
#   1. Go to https://web3forms.com
#   2. Click "Create your Access Key"
#   3. Enter the email that will receive form submissions:
#        → jeanpaulfrago10@gmail.com
#   4. Confirm via the email Web3Forms sends you
#   5. Copy the access key string here AND in Vercel's env vars
#
# Local development: copy this file to `.env.local` and fill in.
# Production: set the same variable in Vercel → Project → Settings → Environment Variables.

WEB3FORMS_ACCESS_KEY=replace-me-with-your-web3forms-key
